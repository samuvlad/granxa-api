# Base de datos
DATABASE_URL=postgresql+psycopg2://granxa:granxa@localhost:5432/granxa_maps

# API
API_HOST=0.0.0.0
API_PORT=8000

# Echo de SQL en logs (false en producion)
DB_ECHO=false

# Executar migracións no arranque do contedor (1=si, 0=no)
# En produción con múltiples réplicas, considerar desactivalo e executar
# as migracións nun init container ou job separado.
RUN_MIGRATIONS=1

# Autenticación (JWT). Cambia JWT_SECRET en produción por un valor
# aleatorio longo (ex.: `openssl rand -hex 32`).
JWT_SECRET=change-me-in-production-please-this-is-not-secure
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
